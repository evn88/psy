datasource db {
  provider = "postgresql"
}

// Определение пути вывода для сгенерированного Prisma Client
generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  USER
  GUEST
}

/// Статус бронирования события
enum EventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  PENDING_CONFIRMATION
}

/// Тип события в календаре
enum EventType {
  CONSULTATION
  FREE_SLOT
  DAY_OFF
  VACATION
  SICK_LEAVE
  OTHER
}

/// Тип вопроса в опросе
enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  TEXT
  SCALE
}

/// Статус назначения опроса пользователю
enum AssignmentStatus {
  PENDING
  COMPLETED
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role            @default(GUEST)
  isDisabled    Boolean         @default(false)
  timezone      String?         @default("UTC")
  accounts      Account[]
  sessions      Session[]
  // Опционально для поддержки WebAuthn
  Authenticator Authenticator[]
  loginHistory  UserLoginHistory[]

  language       String    @default("ru")
  theme          String    @default("system")
  lastSeen       DateTime? @default(now())
  registrationIp String?

  googleCalendarSyncUrl     String?
  googleCalendarSyncEnabled Boolean @default(false)
  workHourStart             Int     @default(9)
  workHourEnd               Int     @default(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи с системой опросов
  createdSurveys    Survey[]           @relation("SurveyCreator")
  surveyAssignments SurveyAssignment[]
  surveyComments    SurveyComment[]

  // Связи с расписанием
  createdEvents Event[] @relation("EventCreator")
  clientEvents  Event[] @relation("EventClient")

  // Push-подписки (PWA)
  pushSubscriptions PushSubscription[]

  // Блог
  blogNotifications Boolean   @default(false)
  blogPosts         BlogPost[] @relation("BlogAuthor")
}

/// Подписка на Web Push уведомления (PWA)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Опционально для поддержки WebAuthn
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  createdAt DateTime @default(now())
}

// ============================================================
// Система опросов
// ============================================================

/// Опрос, созданный администратором
model Survey {
  id          String  @id @default(cuid())
  title       String
  description String?
  createdById String
  createdBy   User    @relation("SurveyCreator", fields: [createdById], references: [id], onDelete: Cascade)

  questions   SurveyQuestion[]
  assignments SurveyAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Вопрос опроса
model SurveyQuestion {
  id        String       @id @default(cuid())
  surveyId  String
  survey    Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text      String
  type      QuestionType
  options   Json? // Варианты ответа для SINGLE_CHOICE / MULTI_CHOICE / SCALE
  order     Int          @default(0)
  isDeleted Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Назначение опроса пользователю
model SurveyAssignment {
  id         String           @id @default(cuid())
  surveyId   String
  survey     Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     AssignmentStatus @default(PENDING)
  isArchived Boolean          @default(false)

  result SurveyResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([surveyId, userId])
}

/// Результат прохождения опроса
model SurveyResult {
  id           String           @id @default(cuid())
  assignmentId String           @unique
  assignment   SurveyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers      Json // { questionId: answer }
  completedAt  DateTime         @default(now())

  comments SurveyComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Комментарий администратора к результату опроса
model SurveyComment {
  id       String       @id @default(cuid())
  resultId String
  result   SurveyResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  authorId String
  author   User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text     String

  isReadByAdmin Boolean @default(false)
  isReadByUser  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// История входов пользователя (хранится не более 3 записей на пользователя)
model UserLoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  provider  String   // "credentials", "google", "webauthn"
  createdAt DateTime @default(now())
}

// ============================================================
// Система расписания и записи (Календарь)
// ============================================================

// ============================================================
// Блог
// ============================================================

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

/// Статья блога
model BlogPost {
  id          String         @id @default(cuid())
  slug        String         @unique
  status      BlogPostStatus @default(DRAFT)
  coverImage  String?
  readingTime Int            @default(0)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  authorId     String
  author       User                  @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  translations BlogPostTranslation[]
  categories   BlogPostCategory[]
  versions     BlogPostVersion[]

  @@index([status, publishedAt])
}

/// Версия статьи (снапшот при ручном сохранении, хранится последние 5)
model BlogPostVersion {
  id           String   @id @default(cuid())
  postId       String
  post         BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  translations Json     // снапшот переводов [{ locale, title, description, content }]
  categoryIds  String[] // снапшот категорий
  coverImage   String?
  savedAt      DateTime @default(now())

  @@index([postId, savedAt])
}

/// Перевод статьи на конкретный язык
model BlogPostTranslation {
  id          String   @id @default(cuid())
  postId      String
  locale      String
  title       String
  description String
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([postId])
}

/// Категория статей блога
model BlogCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      Json // { ru: "...", en: "...", sr: "..." }
  createdAt DateTime @default(now())

  posts BlogPostCategory[]
}

/// Связь статьи с категорией
model BlogPostCategory {
  postId     String
  categoryId String

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

/// Подписка на уведомления о новых статьях блога (для незарегистрированных)
model BlogSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @default(cuid())
  createdAt DateTime @default(now())
}

model Event {
  id             String      @id @default(cuid())
  title          String?
  type           EventType
  status         EventStatus @default(SCHEDULED)
  start          DateTime
  end            DateTime
  meetLink       String?
  cancelReason   String?
  isGoogleSynced Boolean     @default(false)
  googleEventId  String?

  authorId String
  author   User   @relation("EventCreator", fields: [authorId], references: [id], onDelete: Cascade)

  // Юзер, забронировавший слот
  userId String?
  user   User?   @relation("EventClient", fields: [userId], references: [id], onDelete: Cascade)

  groupId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
